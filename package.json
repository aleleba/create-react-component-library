{
  "name": "@aleleba/create-react-component-library",
  "version": "1.2.28",
  "description": "A starter kit for create a React component Library with storybook",
  "bin": "./bin/cli.js",
  "main": "dist/index.js",
  "scripts": {
    "start": "npm run storybook",
    "build": "webpack",
    "lint": "eslint ./ --ext .js --ext .ts --ext .jsx --ext .tsx",
    "lint:fix": "eslint ./ --ext .js --ext .ts --ext .jsx --ext .tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "storybook": "storybook dev -p 3000",
    "build-storybook": "storybook build",
    "check-updates": "npx npm-check-updates -u --reject @types/cypress && npm i --legacy-peer-deps",
    "cy:open": "npx cypress open",
    "cy:run": "npx cypress run --headless --component"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleleba/create-react-component-library.git"
  },
  "keywords": [
    "create",
    "react",
    "component",
    "library",
    "typescript"
  ],
  "author": "Alejandro Lembke Barrientos",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aleleba/create-react-component-library/issues"
  },
  "homepage": "https://github.com/aleleba/create-react-component-library#readme",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/register": "^7.27.1",
    "@mdx-js/react": "^3.1.0",
    "@storybook/addon-docs": "^9.0.17",
    "@storybook/addon-links": "^9.0.17",
    "@storybook/addon-styling-webpack": "^2.0.0",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/cli": "^9.0.17",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react-webpack5": "^9.0.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cypress": "^0.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/webpack": "^5.28.5",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "cypress": "^14.5.1",
    "dotenv": "^17.2.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^9.0.17",
    "eslint-webpack-plugin": "^5.0.2",
    "html-webpack-plugin": "^5.6.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jest-fetch-mock": "^3.0.3",
    "mini-css-extract-plugin": "^2.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resolve-ts-aliases": "^1.0.1",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "storybook": "^9.0.17",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "files": [
    "./dist"
  ]
}
